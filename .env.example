# LLM configuration (MANDATORY)
# Provide your OpenAI API key for text embeddings and chat.
OPENAI_API_KEY=""

# The threshold for flagging unconfident answers and escalating to a human.
CONFIDENCE_THRESHOLD="0.35"

# The LLM model to use (default: gpt-4o)
LLM_MODEL="gpt-4o"

# Admin credentials for initial setup
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@dolphi.ai"
ADMIN_PASSWORD="super_secret_admin_pw"

# Secret key for session tokens
SECRET_KEY="a_very_long_random_string_for_flask_session_signing"

# Security & Registration
# Base domain (with protocol) for building invitation and verification URLs
BASE_URL="http://localhost:3000"



# ADMIN_ACCESS_CODE is a secret code that grants admin role on registration. Share this only with intended administrators. Use a strong random value of at least 16 characters. Change this value periodically.
ADMIN_ACCESS_CODE="REPLACE_ME_WITH_RANDOM"
